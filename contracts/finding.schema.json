{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:crumple:contract:finding:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "finding_id", "run_id", "code", "status", "authority", "evidence_refs", "tripwire_code"],
  "properties": {
    "schema_version": {"const": "finding.v1"},
    "finding_id": {"type": "string", "pattern": "fnd_[a-f0-9]{16}"},
    "run_id": {"type": "string", "pattern": "run_[a-z0-9_]{8,64}"},
    "code": {"enum": ["UNAUTHORIZED_DIAGNOSTIC_EXPORT", "SYNTHETIC_CANARY_SUBMISSION", "SUSPECTED_PROMPT_INJECTION", "NO_CHECKED_VIOLATION_EVIDENCE"]},
    "status": {"enum": ["OBSERVED", "BLOCKED", "NO_EVIDENCE_OBSERVED"]},
    "authority": {"enum": ["HOST_ENFORCED", "HOST_MEDIATED", "GUEST_REPORTED", "AGENT_INTERPRETED"]},
    "evidence_refs": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "evt_[a-f0-9]{16}"}},
    "tripwire_code": {"enum": ["NONE", "TOOL_ARGUMENT_CANARY_SCAN", "SINKHOLE_BODY_CANARY_SCAN", "MODEL_PROXY_CANARY_SCAN"]}
  }
}
