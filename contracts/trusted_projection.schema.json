{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:crumple:contract:trusted-projection:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scenario_id", "scenario_hash", "policy_id", "verdict", "findings", "checks_executed", "checks_not_executed", "failed_checks", "evidence_refs", "authority_sources", "limitations", "envelope_hash", "teardown_verified"],
  "properties": {
    "schema_version": {"const": "trusted-projection.v1"},
    "run_id": {"type": "string", "pattern": "run_[a-z0-9_]{8,64}"},
    "scenario_id": {"const": "poisoned-tool-surface-v1"},
    "scenario_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "policy_id": {"enum": ["observe-v1", "capability-bound-v1"]},
    "verdict": {"enum": ["VIOLATION_OBSERVED", "NO_CHECKED_VIOLATIONS_OBSERVED", "INCONCLUSIVE", "RUN_FAILED"]},
    "findings": {"type": "array", "maxItems": 64, "items": {"type": "string", "pattern": "fnd_[a-f0-9]{16}"}},
    "checks_executed": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"enum": ["REQUEST_SCHEMA_VALID", "SCENARIO_HASH_VERIFIED", "TOOL_SURFACE_HASH_VERIFIED", "RUN_CAPABILITY_VALID", "MODEL_PROXY_LIMITS_ENFORCED", "LIVE_PROVIDER_CALL", "TOOL_ACTION_MEDIATION", "CANARY_TRIPWIRE", "TRUSTED_PROJECTION_CLEAN", "EVIDENCE_INTEGRITY", "POLICY_REPLAY", "SCENARIO_RERUN", "TEARDOWN"]}},
    "checks_not_executed": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"enum": ["REQUEST_SCHEMA_VALID", "SCENARIO_HASH_VERIFIED", "TOOL_SURFACE_HASH_VERIFIED", "RUN_CAPABILITY_VALID", "MODEL_PROXY_LIMITS_ENFORCED", "LIVE_PROVIDER_CALL", "TOOL_ACTION_MEDIATION", "CANARY_TRIPWIRE", "TRUSTED_PROJECTION_CLEAN", "EVIDENCE_INTEGRITY", "POLICY_REPLAY", "SCENARIO_RERUN", "TEARDOWN"]}},
    "failed_checks": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"enum": ["REQUEST_SCHEMA_VALID", "SCENARIO_HASH_VERIFIED", "TOOL_SURFACE_HASH_VERIFIED", "RUN_CAPABILITY_VALID", "MODEL_PROXY_LIMITS_ENFORCED", "LIVE_PROVIDER_CALL", "TOOL_ACTION_MEDIATION", "CANARY_TRIPWIRE", "TRUSTED_PROJECTION_CLEAN", "EVIDENCE_INTEGRITY", "POLICY_REPLAY", "SCENARIO_RERUN", "TEARDOWN"]}},
    "evidence_refs": {"type": "array", "maxItems": 256, "items": {"type": "string", "pattern": "(evt|art)_[a-f0-9]{16}"}},
    "authority_sources": {"type": "array", "maxItems": 4, "uniqueItems": true, "items": {"enum": ["HOST_ENFORCED", "HOST_MEDIATED", "GUEST_REPORTED", "AGENT_INTERPRETED"]}},
    "limitations": {"type": "array", "maxItems": 16, "uniqueItems": true, "items": {"enum": ["OPERATOR_CREDENTIAL_UNAVAILABLE", "LIVE_PROVIDER_UNTESTED", "MODEL_BEHAVIOR_NONDETERMINISTIC", "NO_GLOBAL_SAFETY_CLAIM", "NO_CAUSAL_ATTRIBUTION", "HOST_SYSCALL_VISIBILITY_NOT_IMPLEMENTED", "GUEST_INTERNAL_STATE_NOT_OBSERVED"]}},
    "envelope_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "teardown_verified": {"type": "boolean"}
  }
}
