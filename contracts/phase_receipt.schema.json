{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:crumple:contract:phase-receipt:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_schema_version", "phase_id", "objective", "started_at", "completed_at", "repository_commit_before", "repository_commit_after", "versions", "declared_files", "actual_changed_files", "assumptions", "commands_executed", "tests_and_falsifiers", "generated_artifacts", "invariants_exercised", "authority_claims", "limitations_and_checks_not_run", "detected_drift", "repair_attempts", "final_verdict", "next_admitted_phase", "stop_reason"],
  "properties": {
    "receipt_schema_version": {"const": "phase-receipt.v1"},
    "phase_id": {"type": "string", "pattern": "PHASE_[0-6]"},
    "objective": {"type": "string", "minLength": 1, "maxLength": 2048},
    "started_at": {"type": "string", "pattern": "[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.+-]+"},
    "completed_at": {"type": "string", "pattern": "[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.+-]+"},
    "repository_commit_before": {"type": "string", "pattern": "[a-f0-9]{40}"},
    "repository_commit_after": {"type": "string", "pattern": "([a-f0-9]{40}|WORKTREE_[A-Z0-9_]+)"},
    "versions": {"type": "object"},
    "declared_files": {"type": "array", "maxItems": 512, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "actual_changed_files": {"type": "array", "maxItems": 512, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "assumptions": {"type": "array", "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 2048}},
    "commands_executed": {"type": "array", "maxItems": 1024, "items": {"type": "object"}},
    "tests_and_falsifiers": {"type": "array", "maxItems": 512, "items": {"type": "object"}},
    "generated_artifacts": {"type": "array", "maxItems": 512, "items": {"type": "object"}},
    "invariants_exercised": {"type": "array", "maxItems": 17, "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 17}},
    "authority_claims": {"type": "array", "maxItems": 128, "items": {"type": "object"}},
    "limitations_and_checks_not_run": {"type": "array", "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 2048}},
    "detected_drift": {"type": "array", "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 2048}},
    "repair_attempts": {"type": "array", "maxItems": 2, "items": {"type": "object"}},
    "final_verdict": {"enum": ["PASS", "REPAIRED_PASS", "FAILED", "MAP_CHANGE_REQUIRED"]},
    "next_admitted_phase": {"enum": ["PHASE_1", "PHASE_2", "PHASE_3", "PHASE_4", "PHASE_5", "PHASE_6", "NONE"]},
    "stop_reason": {"type": "string", "maxLength": 2048}
  }
}
