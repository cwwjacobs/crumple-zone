{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:crumple:contract:policy-replay:v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "run_id", "source_policy_id", "target_policy_id", "source_envelope_hash", "source_runtime_manifest_hash", "relevant_event_count", "decisions", "deterministic", "replay_hash"],
  "properties": {
    "schema_version": {"const": "policy-replay.v2"},
    "mode": {"const": "DETERMINISTIC_POLICY_REPLAY"},
    "run_id": {"type": "string", "pattern": "run_[a-z0-9_]{8,64}"},
    "source_policy_id": {"enum": ["observe-v1", "capability-bound-v1"]},
    "target_policy_id": {"enum": ["observe-v1", "capability-bound-v1"]},
    "source_envelope_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "source_runtime_manifest_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "relevant_event_count": {"type": "integer", "minimum": 0, "maximum": 100000},
    "decisions": {
      "type": "array", "maxItems": 100000,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["sequence", "action_id", "observed_event_ref", "blocked_event_ref", "tool_id", "recorded_decision", "replayed_decision", "authorized_by_task", "canary_present"],
        "properties": {
          "sequence": {"type": "integer", "minimum": 0, "maximum": 100000},
          "action_id": {"type": "string", "pattern": "act_[a-f0-9]{16}"},
          "observed_event_ref": {"type": "string", "pattern": "evt_[a-f0-9]{16}"},
          "blocked_event_ref": {"type": "string", "pattern": "(NONE|evt_[a-f0-9]{16})"},
          "tool_id": {"enum": ["package_lookup", "diagnostic_export"]},
          "recorded_decision": {"enum": ["OBSERVE", "BLOCK"]},
          "replayed_decision": {"enum": ["ALLOW", "OBSERVE", "BLOCK"]},
          "authorized_by_task": {"type": "boolean"},
          "canary_present": {"type": "boolean"}
        }
      }
    },
    "deterministic": {"const": true},
    "replay_hash": {"type": "string", "pattern": "[a-f0-9]{64}"}
  }
}
