{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:crumple:contract:evidence-envelope:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scenario_id", "scenario_hash", "tool_surface_hash", "policy_id", "events", "findings", "artifacts", "checks", "previous_envelope_hash", "envelope_hash"],
  "properties": {
    "schema_version": {"const": "evidence-envelope.v1"},
    "run_id": {"type": "string", "pattern": "run_[a-z0-9_]{8,64}"},
    "scenario_id": {"const": "poisoned-tool-surface-v1"},
    "scenario_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "tool_surface_hash": {"type": "string", "pattern": "[a-f0-9]{64}"},
    "policy_id": {"enum": ["observe-v1", "capability-bound-v1"]},
    "events": {"type": "array", "maxItems": 100000, "items": {"type": "object"}},
    "findings": {"type": "array", "maxItems": 64, "items": {"type": "object"}},
    "artifacts": {
      "type": "array", "maxItems": 128,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["artifact_id", "media_code", "sha256", "size_bytes", "quarantined"],
        "properties": {
          "artifact_id": {"type": "string", "pattern": "art_[a-f0-9]{16}"},
          "media_code": {"enum": ["SCENARIO_JSON", "TOOL_SURFACE_JSON", "GUEST_JSONL", "GUEST_STDERR", "GUEST_FILE", "FIRECRACKER_LOG", "POLICY_REPLAY_JSON"]},
          "sha256": {"type": "string", "pattern": "[a-f0-9]{64}"},
          "size_bytes": {"type": "integer", "minimum": 0, "maximum": 1073741824},
          "quarantined": {"type": "boolean"}
        }
      }
    },
    "checks": {
      "type": "object", "additionalProperties": false,
      "required": ["executed", "not_executed", "failed"],
      "properties": {
        "executed": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "[A-Z][A-Z0-9_]{2,63}"}},
        "not_executed": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "[A-Z][A-Z0-9_]{2,63}"}},
        "failed": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "[A-Z][A-Z0-9_]{2,63}"}}
      }
    },
    "previous_envelope_hash": {"type": "string", "pattern": "(NONE|[a-f0-9]{64})"},
    "envelope_hash": {"type": "string", "pattern": "[a-f0-9]{64}"}
  }
}
